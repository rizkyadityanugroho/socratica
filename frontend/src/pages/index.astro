---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ════════════════════════════════════════════ -->
  <!-- LANDING PAGE — visible in empty state        -->
  <!-- Hidden by ChatApp when session starts        -->
  <!-- ════════════════════════════════════════════ -->
  <div id="socratica-root">

    <!-- ─── LANDING VIEW ─── -->
    <div id="landing-view" class="min-h-screen flex flex-col">

      <!-- Header -->
      <header class="flex items-center justify-between px-10 py-6 border-b border-gray-200">
        <h1 class="text-2xl font-serif font-bold tracking-tight text-charcoal">Socratica</h1>
        <nav class="flex items-center gap-8 text-sm uppercase tracking-widest text-gray-500">
          <a href="#" class="hover:text-charcoal transition-colors">Inquiry</a>
          <a href="#" class="hover:text-charcoal transition-colors">Library</a>
          <div class="w-8 h-8 rounded-full border-2 border-gray-300 flex items-center justify-center">
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </div>
        </nav>
      </header>

      <!-- Hero -->
      <main class="flex-1 flex flex-col items-center justify-center px-6 max-w-4xl mx-auto w-full">
        <div class="text-center mb-16">
          <p class="font-serif italic text-4xl md:text-5xl lg:text-6xl text-charcoal leading-tight">
            "The unexamined life<br class="sm:hidden"> is not worth living"
          </p>
        </div>

        <!-- Input area -->
        <div class="w-full max-w-xl mx-auto">
          <input
            id="landing-input"
            type="text"
            placeholder="What's on your mind?"
            class="w-full text-center text-lg font-light italic text-gray-700 placeholder-gray-400 bg-transparent border-none outline-none pb-4"
            autocomplete="off"
          />
          <div class="w-full h-px bg-gray-300 mb-6"></div>
          <div class="flex justify-center gap-4">
            <button id="btn-begin-dialogue" class="px-8 py-3 border border-charcoal text-charcoal text-sm uppercase tracking-widest hover:bg-charcoal hover:text-white transition-colors">
              Begin Dialogue
            </button>
            <button id="btn-enter-landing" class="px-8 py-3 border border-charcoal text-charcoal text-sm uppercase tracking-widest hover:bg-charcoal hover:text-white transition-colors">
              Enter
            </button>
          </div>
        </div>

        <!-- Three columns -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mt-24 mb-16 max-w-4xl w-full px-4">
          <div class="text-center">
            <h3 class="text-sm uppercase tracking-[0.2em] text-[#B8860B] font-sans font-semibold mb-4">Method</h3>
            <p class="text-sm text-gray-600 leading-relaxed font-light">
              Through disciplined questioning, we strip away assumptions until only clarity remains.
            </p>
          </div>
          <div class="text-center">
            <h3 class="text-sm uppercase tracking-[0.2em] text-[#B8860B] font-sans font-semibold mb-4">Intent</h3>
            <p class="text-sm text-gray-600 leading-relaxed font-light">
              Not to answer, but to illuminate. The path is carved by your own reasoning.
            </p>
          </div>
          <div class="text-center">
            <h3 class="text-sm uppercase tracking-[0.2em] text-[#B8860B] font-sans font-semibold mb-4">Archive</h3>
            <p class="text-sm text-gray-600 leading-relaxed font-light">
              Every dialogue is ephemeral. Nothing is stored. Nothing is tracked.
            </p>
          </div>
        </div>
      </main>

      <!-- Footer -->
      <footer class="border-t border-gray-200 py-6 px-10">
        <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-gray-400">
          <p class="tracking-wider font-sans">&copy; SOCRATICA — THE UNEXAMINED LIFE IS NOT WORTH LIVING</p>
          <nav class="flex gap-6 uppercase tracking-widest">
            <a href="#" class="hover:text-gray-600 transition-colors">Ethics</a>
            <a href="#" class="hover:text-gray-600 transition-colors">Privacy</a>
            <a href="#" class="hover:text-gray-600 transition-colors">Archive</a>
          </nav>
        </div>
      </footer>
    </div>

    <!-- ─── CHAT VIEW (initially hidden) ─── -->
    <div id="chat-view" class="min-h-screen hidden">
      <!-- Two-column layout -->
      <div class="flex h-screen">

        <!-- Sidebar -->
        <aside id="chat-sidebar" class="w-[250px] min-w-[200px] bg-white border-r border-gray-200 flex flex-col flex-shrink-0">
          <!-- Branding -->
          <div class="px-6 pt-8 pb-6 border-b border-gray-100">
            <h2 class="text-xl font-serif font-bold text-charcoal">Socratica</h2>
          </div>

          <!-- Nav -->
          <nav class="flex-1 px-4 py-6 space-y-1">
            <a href="#" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-500 hover:text-charcoal hover:bg-gray-50 rounded transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/></svg>
              New Session
            </a>
            <a href="#" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-500 hover:text-charcoal hover:bg-gray-50 rounded transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              History
            </a>
            <a href="#" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-500 hover:text-charcoal hover:bg-gray-50 rounded transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
              Notebook
            </a>
            <a href="#" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-500 hover:text-charcoal hover:bg-gray-50 rounded transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              Profile
            </a>
          </nav>

          <!-- User profile -->
          <div class="px-6 py-4 border-t border-gray-100">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-9 h-9 rounded-full bg-gray-200 flex items-center justify-center text-xs font-semibold text-gray-500">S</div>
              <div>
                <p class="text-sm font-medium text-charcoal">Seeker</p>
                <p class="text-[10px] uppercase tracking-widest text-gray-400">Level IV Inquirer</p>
              </div>
            </div>
            <button id="btn-conclude-sidebar" class="w-full py-2 px-3 border border-gray-300 text-xs uppercase tracking-widest text-gray-500 hover:border-charcoal hover:text-charcoal transition-colors rounded">
              Conclude Session
            </button>
          </div>

          <!-- Bottom links -->
          <div class="px-6 py-4 border-t border-gray-100 flex justify-between text-[10px] uppercase tracking-widest text-gray-400">
            <a href="#" class="hover:text-gray-600">Settings</a>
            <a href="#" class="hover:text-gray-600">Help</a>
          </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col bg-offwhite min-w-0">

          <!-- Session Header -->
          <div class="px-10 pt-8 pb-4 border-b border-gray-200 bg-white">
            <div class="flex items-center gap-2 text-[10px] uppercase tracking-[0.15em] text-gray-400 mb-1">
              <span class="w-2 h-2 rounded-full bg-[#B8860B]"></span>
              <span>Current Session</span>
            </div>
            <div class="flex items-center justify-between">
              <h3 id="session-title" class="text-sm font-medium text-charcoal">Exploring Your Question</h3>
              <span id="session-time" class="text-xs italic text-gray-400"></span>
            </div>
          </div>

          <!-- Messages -->
          <div id="messages-container" class="flex-1 overflow-y-auto px-8 md:px-14 py-8 space-y-6">
            <!-- Messages rendered by ChatApp.js -->
          </div>

          <!-- Loading indicator -->
          <div id="loading-indicator" class="hidden px-14 pb-4">
            <div class="flex items-center gap-2 text-sm text-gray-400 italic">
              <div class="flex gap-1">
                <span class="w-1.5 h-1.5 rounded-full bg-gray-400 animate-bounce" style="animation-delay:0ms"></span>
                <span class="w-1.5 h-1.5 rounded-full bg-gray-400 animate-bounce" style="animation-delay:150ms"></span>
                <span class="w-1.5 h-1.5 rounded-full bg-gray-400 animate-bounce" style="animation-delay:300ms"></span>
              </div>
              <span>Socratica is formulating...</span>
            </div>
          </div>

          <!-- Input Bar -->
          <div class="px-8 md:px-14 py-6 border-t border-gray-200 bg-white">
            <div class="max-w-3xl">
              <div class="flex items-center gap-3">
                <input
                  id="chat-input"
                  type="text"
                  placeholder="Reflect on your motivation..."
                  class="flex-1 bg-transparent border-none outline-none text-sm text-charcoal placeholder-gray-400 font-light italic"
                  autocomplete="off"
                />
                <button id="btn-send" class="px-6 py-2 bg-charcoal text-white text-xs uppercase tracking-widest hover:bg-gray-700 transition-colors disabled:opacity-30 disabled:cursor-not-allowed rounded">
                  Send
                </button>
              </div>
              <div class="flex items-center gap-6 mt-3">
                <button id="btn-notebook" class="text-[10px] uppercase tracking-widest text-gray-400 hover:text-gray-600 transition-colors">Add to Notebook</button>
                <button id="btn-export" class="text-[10px] uppercase tracking-widest text-gray-400 hover:text-gray-600 transition-colors">Export Transcript</button>
                <button id="btn-conclude" class="ml-auto text-[10px] uppercase tracking-widest text-coral hover:text-red-500 transition-colors font-medium">
                  Conclude
                </button>
              </div>
            </div>
          </div>
        </main>
      </div>
    </div>

    <!-- ─── CONCLUDED VIEW (initially hidden) ─── -->
    <div id="concluded-view" class="min-h-screen flex flex-col items-center justify-center px-6 hidden">
      <div class="max-w-xl text-center">
        <p class="text-xs uppercase tracking-[0.25em] text-gray-400 mb-6">Your Conclusion</p>
        <p id="conclusion-summary" class="font-serif italic text-2xl md:text-3xl text-charcoal leading-relaxed mb-10"></p>
        <button id="btn-start-over" class="px-8 py-3 border border-charcoal text-charcoal text-sm uppercase tracking-widest hover:bg-charcoal hover:text-white transition-colors">
          Start Over
        </button>
      </div>
    </div>

  </div>

  <!-- Import and bundle ChatApp via Astro/Vite -->
  <script>
    import '../components/ChatApp.js';
  </script>
</Layout>
